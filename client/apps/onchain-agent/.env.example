# Option 1: Auto-discovery (recommended) — just provide world name
CHAIN=slot
WORLD_NAME=xbt5
MODEL_ID=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
# REGISTER AND START THE GAME VIA THE GAME CLIENT YOURSELF FIRST.
# ONCE YOU SETTLE YOUR REALMS, THEN START UP THE GAME
# ----------------------------------------------------
# Option 2: Explicit config — provide URLs directly - NOT NEEDED - DEV ONLY
# TORII_URL=https://api.cartridge.gg/x/eternum-torii/torii
# WORLD_ADDRESS=0x...

# Optional (defaults shown)
# RPC_URL=https://api.cartridge.gg/x/starknet/mainnet  # defaults based on CHAIN
# CHAIN_ID=SN_MAIN
# MODEL_PROVIDER=anthropic
# MODEL_ID=claude-haiku-4-5-20251001
# TICK_INTERVAL_MS=60000

# ----------------------------------------------------
# Option 3: x402 provider — pay-per-request via on-chain USDC permits
# MODEL_PROVIDER=x402
# X402_PRIVATE_KEY=0x...          # wallet private key for signing USDC permits
# X402_ROUTER_URL=https://ai.xgate.run  # default router
# X402_MODEL_ID=kimi-k2.5        # any model from ai.xgate.run/v1/models
# X402_NETWORK=eip155:8453        # Base mainnet (default)
# X402_PERMIT_CAP=10000000        # max USDC per permit in base units
