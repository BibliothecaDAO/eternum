# Axis Configuration
# This file is auto-loaded from ~/.eternum-agent/.env on every run.
# Shell environment variables override values set here.
# Run `axis init` to create this file, then edit it.

# --- Required: Set your LLM API key ---
MODEL_PROVIDER=anthropic
MODEL_ID=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Agent behavior ---
GAME_NAME=eternum
TICK_INTERVAL_MS=60000
LOOP_ENABLED=true

# INFO + EXAMPLES
#
# RPC_URL=https://api.cartridge.gg/x/eternum-blitz-slot-4/katana
# TORII_URL=https://api.cartridge.gg/x/testy-testy-9/torii/sql
# WORLD_ADDRESS=0x013dee1ed7fb318718aa5a47a8f2f5ff7aea36429d1c6e6e5446f8d8dc3956aa
# SLOT NAME IS THE NAME OF THE TORII - ASSOCIATED WITH THE USER FACING 'NAME'
# SEE SUPPORTED PI-AGENT MODELS FOR FULL LUST
# --- Session storage ---
# SESSION_BASE_PATH=~/.eternum-agent/.cartridge

# --- Optional: auto top-up fee tokens (non-mainnet only) ---
# MASTER_ADDRESS=0x...
# MASTER_PRIVATE_KEY=0x...

# --- Optional: skip world discovery ---
# SLOT_NAME=my-world-name
# CHAIN=slot

# --- Optional: manual world connection (skips discovery) ---
# RPC_URL=https://api.cartridge.gg/x/starknet/mainnet
# TORII_URL=https://api.cartridge.gg/x/my-world/torii
# WORLD_ADDRESS=0x...
